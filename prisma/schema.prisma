generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model categories {
  id               Int          @id @default(autoincrement())
  name             String       @db.VarChar(255)
  parent_id        Int?
  created_at       DateTime?    @default(now()) @db.Timestamp(6)
  categories       categories?  @relation("categoriesTocategories", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_categories categories[] @relation("categoriesTocategories")
  products         products[]
}

model order_items {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id           String?           @db.Uuid
  shop_id            String?           @db.Uuid
  product_variant_id String?           @db.Uuid
  quantity           Int
  price              Decimal           @db.Decimal(12, 2)
  status             String?           @default("pending") @db.VarChar(30)
  created_at         DateTime?         @default(now()) @db.Timestamp(6)
  received_at        DateTime?         @db.Timestamp(6)
  return_deadline_at DateTime?         @db.Timestamp(6)
  payout_available_at DateTime?        @db.Timestamp(6)
  orders             orders?           @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_variants   product_variants? @relation(fields: [product_variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shops              shops?            @relation(fields: [shop_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  returns            returns[]
  shipments          shipments[]
  shop_payout        shop_payouts?

  @@index([shop_id])
  @@index([status])
  @@index([received_at])
  @@index([payout_available_at])
}

model orders {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String?       @db.Uuid
  total_amount   Decimal?      @db.Decimal(12, 2)
  payment_method String?       @db.VarChar(20)
  payment_status String?       @default("pending") @db.VarChar(20)
  order_status   String?       @default("pending") @db.VarChar(30)
  created_at     DateTime?     @default(now()) @db.Timestamp(6)
  order_items    order_items[]
  users          users?        @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model product_variants {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id  String?       @db.Uuid
  sku         String?       @unique @db.VarChar(100)
  price       Decimal       @db.Decimal(12, 2)
  stock       Int?          @default(0)
  weight      Int?
  created_at  DateTime?     @default(now()) @db.Timestamp(6)
  order_items order_items[]
  cart_items  cart_items[]
  products    products?     @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model products {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id          String?            @db.Uuid
  category_id      Int?
  name             String             @db.VarChar(255)
  description      String?
  status           String?            @default("active") @db.VarChar(20)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  product_variants product_variants[]
  categories       categories?        @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shops            shops?             @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reviews          reviews[]
}

model returns {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_item_id String?      @db.Uuid
  reason        String?
  status        String?      @default("requested") @db.VarChar(30)
  refund_amount Decimal?     @db.Decimal(12, 2)
  approved_by   String?      @db.Uuid
  rejected_reason String?    @db.VarChar(255)
  resolved_at   DateTime?    @db.Timestamp(6)
  dispute_reason String?     @db.VarChar(255)
  dispute_status String?     @db.VarChar(30)
  disputed_at   DateTime?    @db.Timestamp(6)
  dispute_resolved_at DateTime? @db.Timestamp(6)
  dispute_resolved_by String? @db.Uuid
  dispute_resolution String? @db.VarChar(255)
  created_at    DateTime?    @default(now()) @db.Timestamp(6)
  order_items   order_items? @relation(fields: [order_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id String?   @db.Uuid
  user_id    String?   @db.Uuid
  rating     Int?
  comment    String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  products   products? @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model shipments {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_item_id   String?      @db.Uuid
  tracking_code   String?      @db.VarChar(100)
  shipping_status String?      @default("waiting_pickup") @db.VarChar(30)
  shipped_at      DateTime?    @db.Timestamp(6)
  delivered_at    DateTime?    @db.Timestamp(6)
  created_at      DateTime?    @default(now()) @db.Timestamp(6)
  order_items     order_items? @relation(fields: [order_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model shop_addresses {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String?   @db.Uuid
  province   String?   @db.VarChar(100)
  district   String?   @db.VarChar(100)
  ward       String?   @db.VarChar(100)
  detail     String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  shops      shops?    @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model shop_payment_accounts {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id        String?   @db.Uuid
  bank_name      String?   @db.VarChar(100)
  account_number String?   @db.VarChar(100)
  account_holder String?   @db.VarChar(255)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  shops          shops?    @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model shop_documents {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id     String?   @db.Uuid
  doc_type    String?   @db.VarChar(50)
  doc_url     String?   @db.VarChar(500)
  status      String?   @default("pending") @db.VarChar(30)
  note        String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  reviewed_at DateTime? @db.Timestamp(6)
  shops       shops?    @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([shop_id])
  @@index([status])
}

model shops {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id              String?                 @db.Uuid
  name                  String                  @db.VarChar(255)
  description           String?
  status                String?                 @default("pending") @db.VarChar(20)
  approved_by           String?                 @db.Uuid
  rejected_reason       String?                 @db.VarChar(255)
  approved_at           DateTime?               @db.Timestamp(6)
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  order_items           order_items[]
  products              products[]
  shop_addresses        shop_addresses[]
  shop_payment_accounts shop_payment_accounts[]
  shop_documents        shop_documents[]
  shop_payouts          shop_payouts[]
  users                 users?                  @relation("shopsOwner", fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  approved_by_user      users?                  @relation("shopsApprovedBy", fields: [approved_by], references: [id], onDelete: SetNull, onUpdate: NoAction)
}

model user_addresses {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  province   String?   @db.VarChar(100)
  district   String?   @db.VarChar(100)
  ward       String?   @db.VarChar(100)
  detail     String?
  is_default Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String           @unique @db.VarChar(255)
  password_hash  String
  full_name      String?          @db.VarChar(255)
  phone          String?          @db.VarChar(20)
  role           String?          @default("customer") @db.VarChar(20)
  status         String?          @default("active") @db.VarChar(20)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)
  orders         orders[]
  reviews        reviews[]
  shops          shops[]          @relation("shopsOwner")
  approved_shops shops[]          @relation("shopsApprovedBy")
  user_addresses user_addresses[]
  wallets        wallets[]
  refresh_tokens refresh_tokens[]
  cart_items     cart_items[]
}

model cart_items {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String           @db.Uuid
  product_variant_id String           @db.Uuid
  quantity           Int              @default(1)
  created_at         DateTime?        @default(now()) @db.Timestamp(6)
  updated_at         DateTime?        @default(now()) @db.Timestamp(6)
  users              users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_variants   product_variants @relation(fields: [product_variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, product_variant_id])
  @@index([user_id])
  @@index([product_variant_id])
}

model shop_payouts {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_item_id String    @unique @db.Uuid
  shop_id       String    @db.Uuid
  gross_amount  Decimal   @db.Decimal(12, 2)
  fee_amount    Decimal   @db.Decimal(12, 2)
  net_amount    Decimal   @db.Decimal(12, 2)
  status        String?   @default("pending") @db.VarChar(30)
  available_at  DateTime? @db.Timestamp(6)
  paid_at       DateTime? @db.Timestamp(6)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  order_items   order_items @relation(fields: [order_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  shops         shops     @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([shop_id])
  @@index([status])
  @@index([available_at])
}

model refresh_tokens {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique @db.VarChar(64)
  expires_at DateTime  @db.Timestamp(6)
  revoked_at DateTime? @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
  @@index([expires_at])
}

model wallet_transactions {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet_id    String?   @db.Uuid
  amount       Decimal?  @db.Decimal(14, 2)
  type         String?   @db.VarChar(20)
  reference_id String?   @db.Uuid
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  wallets      wallets?  @relation(fields: [wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model wallets {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String?               @db.Uuid
  balance             Decimal?              @default(0) @db.Decimal(14, 2)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  wallet_transactions wallet_transactions[]
  users               users?                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
